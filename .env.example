PORT=3000
NODE_ENV=development

# Repository layouts stay in ./exports. Point this at a Railway volume for hosted persistence.
MAZE_EXPORTS_DIR=./exports

# Keep the published default maze pinned for new rooms unless you intentionally switch it.
DEFAULT_PLAY_LAYOUT_FILE=DENUG-layout.json

# GM tools stay enabled automatically outside production.
MAZE_ENABLE_GM_TOOLS=false
